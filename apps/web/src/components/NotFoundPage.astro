---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout locale="ja" title="404" description="Page not found" alternatePath="/en/support/">
  <section class="not-found">
    <p class="error-code">4<span>0</span>4</p>
    <h1>ページが見つかりません</h1>
    <p>The requested pixel is outside the canvas.</p>
    <a class="button" href="/">入口へ戻る</a>
  </section>
</BaseLayout>
