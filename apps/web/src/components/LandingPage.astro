---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout locale="ja" title="Support" description="Pixel Forge support, privacy policy, and terms in Japanese and English." alternatePath="/en/support/">
  <section class="landing-shell">
    <div class="landing-copy">
      <p class="eyebrow">LOCAL / DETERMINISTIC / PIXEL</p>
      <h1>写真を、<br /><em>ピクセル</em>へ。</h1>
      <p class="lede">Pixel Forgeのサポート、プライバシーポリシー、利用規約を日本語と英語で案内します。</p>
    </div>
    <div class="language-cards" aria-label="Language selection">
      <a href="/ja/support/">
        <span>JA</span>
        <strong>日本語</strong>
        <small>サポートを開く</small>
      </a>
      <a href="/en/support/" lang="en">
        <span>EN</span>
        <strong>English</strong>
        <small>Open support</small>
      </a>
    </div>
  </section>
</BaseLayout>
